---
import { Image } from 'astro:assets';

import carrierLogo from '../assets/brands/carrier-logo.svg';
import panasonicLogo from '../assets/brands/panasonic-logo.svg';
import daikinLogo from '../assets/brands/daikin-logo.svg';
import lgLogo from '../assets/brands/lg-logo.svg';
import mideaLogo from '../assets/brands/midea-logo.svg';
import mirageLogo from '../assets/brands/mirage-logo.png';
import yorkLogo from '../assets/brands/york-logo.png';
import samsungLogo from '../assets/brands/samsung-logo.svg';

const brands = [
  { name: 'Carrier', logo: carrierLogo },
  { name: 'Panasonic', logo: panasonicLogo },
  { name: 'Daikin', logo: daikinLogo },
  { name: 'LG', logo: lgLogo },
  { name: 'Midea', logo: mideaLogo },
  { name: 'Mirage', logo: mirageLogo },
  { name: 'York', logo: yorkLogo },
  { name: 'Samsung', logo: samsungLogo },
];
---

<section
  id="marcas"
  aria-labelledby="marcas-heading"
  class="overflow-hidden border-y border-bone-dark bg-white py-16"
>
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <!-- Header — h2 mantiene la jerarquía de encabezados; estilado visualmente igual que antes -->
    <h2
      id="marcas-heading"
      class="mb-10 text-center font-body text-sm font-semibold uppercase tracking-widest text-gray-500"
    >
      Marcas con las que trabajamos
    </h2>

    <!-- Brand grid — ul/li para semántica de lista correcta -->
    <ul role="list" class="grid grid-cols-2 gap-4 sm:grid-cols-4 lg:grid-cols-8">
      {
        brands.map((brand) => (
          <li class="group flex items-center justify-center rounded-xl border border-bone-dark bg-bone px-4 py-5 transition-all duration-300 hover:border-blue/20 hover:bg-white hover:shadow-md hover:shadow-navy/8">
            <Image
              src={brand.logo}
              alt={brand.name}
              height={40}
              class="h-10 w-auto object-contain opacity-50 grayscale transition-all duration-300 group-hover:opacity-100 group-hover:grayscale-0"
            />
          </li>
        ))
      }
    </ul>

    <!-- Note — text-gray-500 cumple WCAG 1.4.3 AA (~4.48:1 sobre blanco) -->
    <p class="mt-8 text-center font-body text-sm text-gray-500">
      Instalamos y damos mantenimiento a equipos de todas las marcas principales del mercado
    </p>

    <!-- Trademark disclaimer -->
    <p class="mt-3 text-center font-body text-xs text-gray-400">
      Los nombres y logotipos de las marcas mostradas son propiedad de sus respectivos dueños. Clima
      Hogar no está afiliado, patrocinado ni respaldado por ninguna de estas marcas.
    </p>
  </div>
</section>

---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="¡Cotización recibida! — Clima Hogar SV"
  description="Recibimos tu solicitud de cotización. Te contactaremos en menos de 24 horas."
  robots="noindex, nofollow"
>
  <Header />
  <main class="flex min-h-screen flex-col items-center justify-center bg-bone px-6 py-32">
    <!-- Decorative blobs -->
    <div
      aria-hidden="true"
      class="pointer-events-none fixed -left-32 top-0 h-96 w-96 rounded-full bg-cyan/6 blur-3xl"
    >
    </div>
    <div
      aria-hidden="true"
      class="pointer-events-none fixed -right-24 bottom-0 h-80 w-80 rounded-full bg-blue/8 blur-3xl"
    >
    </div>

    <div class="relative mx-auto w-full max-w-lg text-center">
      <!-- Success icon -->
      <div
        class="mx-auto mb-8 flex h-24 w-24 items-center justify-center rounded-full bg-navy shadow-xl shadow-navy/20"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="44"
          height="44"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-cyan"
          aria-hidden="true"
        >
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
      </div>

      <!-- Heading -->
      <h1 class="font-display text-4xl font-bold leading-tight text-navy lg:text-5xl">
        ¡Solicitud recibida!
      </h1>

      <!-- Divider accent -->
      <div class="mx-auto mt-5 flex items-center justify-center gap-3">
        <div class="h-0.5 w-12 rounded-full bg-cyan"></div>
        <div class="h-0.5 w-4 rounded-full bg-blue/40"></div>
      </div>

      <!-- Message -->
      <p class="mt-6 font-body text-lg leading-relaxed text-gray-600">
        Gracias por contactarnos. Revisaremos tu solicitud y te enviaremos una cotización en{' '}
        <strong class="font-semibold text-navy">menos de 24 horas</strong>.
      </p>

      <!-- What's next -->
      <div
        class="mt-10 rounded-2xl bg-white px-8 py-7 shadow-sm ring-1 ring-bone-dark/60 text-left"
      >
        <p class="font-display text-sm font-bold uppercase tracking-widest text-blue mb-4">
          ¿Qué sigue?
        </p>
        <ol class="flex flex-col gap-4" role="list">
          {
            [
              'Nuestro equipo revisará los detalles de tu solicitud.',
              'Te contactaremos por teléfono o WhatsApp para coordinar.',
              'Recibirás tu cotización detallada sin ningún costo.',
            ].map((step, i) => (
              <li class="flex items-start gap-4">
                <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-navy font-display text-xs font-bold text-white">
                  {i + 1}
                </span>
                <span class="font-body text-sm leading-relaxed text-gray-600 pt-0.5">{step}</span>
              </li>
            ))
          }
        </ol>
      </div>

      <!-- WhatsApp CTA -->
      <p class="mt-8 font-body text-sm text-gray-400">¿Necesitas atención inmediata?</p>
      <a
        href="https://wa.me/50379723918"
        target="_blank"
        rel="noopener noreferrer"
        class="mt-3 inline-flex items-center gap-3 rounded-full bg-[#25D366] px-7 py-3.5 font-display text-sm font-bold text-white shadow-md shadow-[#25D366]/25 transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-[#25D366]/30"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"
          ></path>
        </svg>
        Escríbenos por WhatsApp
        <span class="sr-only">(abre en nueva pestaña)</span>
      </a>

      <!-- Back home -->
      <div class="mt-10">
        <a
          href="/"
          class="font-body text-sm font-semibold text-blue underline-offset-4 hover:underline"
        >
          ← Volver al inicio
        </a>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

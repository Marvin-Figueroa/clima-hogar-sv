const secondaryServices = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2a10 10 0 0 1 10 10c0 5.52-4.48 10-10 10S2 17.52 2 12a10 10 0 0 1 10-10z"/><path d="M12 6v6l4 2"/><path d="M16 16l-4-4-4 4"/></svg>`,
    title: 'Carga de Gas Refrigerante',
    description: 'Revisión y recarga de gas para recuperar el rendimiento de tu equipo.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>`,
    title: 'Diseño y Asesoría',
    description: 'Soluciones personalizadas de climatización según tu espacio y necesidades.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M3 15h18M9 3v18M15 3v18"/></svg>`,
    title: 'Diseño e Instalación de Ductería',
    description: 'Sistemas de distribución de aire eficientes para espacios amplios.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="17 11 21 7 17 3"/><path d="M21 7H9M7 21l-4-4 4-4"/><path d="M3 17h12"/></svg>`,
    title: 'Desinstalación de Equipos',
    description: 'Retiro seguro y cuidadoso de equipos, sin dañar paredes ni estructuras.',
  },
];
---

<section id="servicios" class="relative overflow-hidden bg-bone py-24">
  <!-- Decorative background shapes -->
  <div
    class="pointer-events-none absolute -right-32 -top-32 h-96 w-96 rounded-full bg-cyan/8 blur-3xl"
  >
  </div>
  <div
    class="pointer-events-none absolute -bottom-24 -left-24 h-72 w-72 rounded-full bg-blue/8 blur-3xl"
  >
  </div>

  <div class="relative mx-auto max-w-7xl px-6 lg:px-8">
    <!-- Section header -->
    <div class="mb-16 max-w-2xl">
      <span
        class="mb-4 inline-block font-body text-sm font-semibold uppercase tracking-widest text-blue"
      >
        Lo que hacemos
      </span>
      <h2 class="font-display text-4xl font-bold leading-tight text-navy lg:text-5xl">
        Servicios de aire<br />acondicionado
      </h2>
      <p class="mt-4 font-body text-lg text-gray-500">
        Soluciones completas para hogares y empresas en El Salvador. Desde la instalación hasta la
        emergencia, estamos contigo.
      </p>
    </div>

    <!-- Primary services grid -->
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        primaryServices.map((service) => (
          <article
            class={`group relative flex flex-col rounded-2xl p-7 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl ${
              service.accent
                ? 'bg-navy text-white shadow-lg shadow-navy/20'
                : 'bg-white text-navy shadow-sm hover:shadow-navy/10'
            }`}
          >
            <div
              class={`mb-5 flex h-14 w-14 items-center justify-center rounded-xl transition-colors duration-300 ${
                service.accent
                  ? 'bg-white/10 text-cyan'
                  : 'bg-bone text-blue group-hover:bg-cyan/10 group-hover:text-cyan-dark'
              }`}
              set:html={service.icon}
            />
            <h3
              class={`mb-3 font-display text-xl font-bold ${service.accent ? 'text-white' : 'text-navy'}`}
            >
              {service.title}
            </h3>
            <p
              class={`mb-5 flex-1 whitespace-pre-line font-body text-sm leading-relaxed ${service.accent ? 'text-white/75' : 'text-gray-500'}`}
            >
              {service.description}
            </p>
            <div class="flex flex-wrap gap-2">
              {service.tags.map((tag) => (
                <span
                  class={`rounded-full px-3 py-1 font-body text-xs font-semibold ${
                    service.accent ? 'bg-white/10 text-cyan-light' : 'bg-bone-dark text-gray-600'
                  }`}
                >
                  {tag}
                </span>
              ))}
            </div>
          </article>
        ))
      }
    </div>

    <!-- Divider -->
    <div class="my-14 flex items-center gap-6">
      <div class="h-px flex-1 bg-bone-dark"></div>
      <span class="font-body text-sm font-semibold uppercase tracking-widest text-gray-400"
        >También ofrecemos</span
      >
      <div class="h-px flex-1 bg-bone-dark"></div>
    </div>

    <!-- Secondary services row -->
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {
        secondaryServices.map((service) => (
          <article class="group flex items-start gap-4 rounded-xl bg-white p-5 shadow-sm transition-all duration-300 hover:-translate-y-0.5 hover:shadow-md hover:shadow-navy/8">
            <div
              class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-bone text-blue transition-colors duration-300 group-hover:bg-cyan/10 group-hover:text-cyan-dark"
              set:html={service.icon}
            />
            <div>
              <h3 class="mb-1 font-display text-base font-bold text-navy">{service.title}</h3>
              <p class="font-body text-sm leading-relaxed text-gray-500">{service.description}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

---
const reasons = [
  {
    number: '01',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 21 12 17.77 5.82 21 7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>`,
    title: 'Técnicos capacitados',
    description:
      'Personal con experiencia comprobada en instalación, mantenimiento y reparación de sistemas de aire acondicionado de todas las marcas.',
  },
  {
    number: '02',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    title: 'Servicio rápido y puntual',
    description:
      'Atendemos cada solicitud con rapidez y cumplimos con los tiempos acordados. Tu tiempo es valioso y lo respetamos.',
  },
  {
    number: '03',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: 'Materiales y equipos de calidad',
    description:
      'Utilizamos repuestos y materiales confiables para garantizar mejor funcionamiento y mayor duración de los equipos.',
  },
  {
    number: '04',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`,
    title: 'Precios justos y transparentes',
    description:
      'Cotizaciones claras y precios competitivos, sin costos ocultos. Sabes exactamente qué pagas y por qué.',
  },
  {
    number: '05',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>`,
    title: 'Garantía en nuestros trabajos',
    description:
      'Respaldamos cada servicio que realizamos. Si algo no está bien, regresamos a resolverlo sin costo adicional.',
  },
];
---

<section id="por-que-elegirnos" class="relative overflow-hidden bg-navy py-24">
  <div
    class="pointer-events-none absolute -right-40 top-0 h-125 w-125 rounded-full bg-blue/10 blur-3xl"
  >
  </div>
  <div
    class="pointer-events-none absolute -left-24 bottom-0 h-80 w-80 rounded-full bg-cyan/8 blur-3xl"
  >
  </div>

  <div class="relative mx-auto max-w-7xl px-6 lg:px-8">
    <div class="grid gap-16 lg:grid-cols-2 lg:gap-24">
      <!-- Left column: header + star rating -->
      <div class="flex flex-col justify-center">
        <span
          class="mb-4 inline-block font-body text-sm font-semibold uppercase tracking-widest text-cyan"
        >
          ¿Por qué elegirnos?
        </span>
        <h2 class="font-display text-4xl font-bold leading-tight text-white lg:text-5xl">
          5 razones para<br />confiar en nosotros
        </h2>
        <p class="mt-6 font-body text-lg leading-relaxed text-white/65">
          Más de 15 años de experiencia profesional respaldan cada trabajo que realizamos. Hogares y
          empresas en El Salvador confían en nuestro servicio.
        </p>

        <!-- Star rating block -->
        <div class="mt-10 inline-flex items-center gap-4 rounded-2xl bg-white/5 px-6 py-5">
          <div class="flex gap-1" role="img" aria-label="5 estrellas">
            {
              Array.from({ length: 5 }).map(() => (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="22"
                  height="22"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  class="text-cyan"
                  aria-hidden="true"
                >
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 21 12 17.77 5.82 21 7 14.14 2 9.27l6.91-1.01L12 2z" />
                </svg>
              ))
            }
          </div>
          <div class="h-8 w-px bg-white/15"></div>
          <div>
            <p class="font-display text-lg font-bold text-white">5 estrellas</p>
            <p class="font-body text-sm text-white/50">en todos nuestros servicios</p>
          </div>
        </div>
      </div>

      <!-- Right column: reasons list -->
      <div class="flex flex-col gap-5">
        {
          reasons.map((reason) => (
            <article class="group flex items-start gap-5 rounded-2xl bg-white/5 p-6 transition-all duration-300 hover:bg-white/10">
              <div class="flex shrink-0 flex-col items-center gap-2">
                <div class="flex h-14 w-14 items-center justify-center rounded-xl bg-cyan/10 text-cyan transition-colors duration-300 group-hover:bg-cyan/20">
                  <Fragment set:html={reason.icon} />
                </div>
                <span class="font-display text-xs font-bold text-white/20" aria-hidden="true">
                  {reason.number}
                </span>
              </div>
              <div class="pt-1">
                <h3 class="mb-2 font-display text-lg font-bold text-white">{reason.title}</h3>
                <p class="font-body text-sm leading-relaxed text-white/60">{reason.description}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>

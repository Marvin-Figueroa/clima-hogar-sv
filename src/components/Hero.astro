---
const stats = [
  { value: '+15', label: 'años de experiencia' },
  { value: '+500', label: 'instalaciones realizadas' },
  { value: '24/7', label: 'servicio de emergencia' },
  { value: '100%', label: 'garantía en cada trabajo' },
];
---

<section
  id="inicio"
  aria-label="Hero — Clima Hogar SV"
  class="relative flex min-h-screen flex-col overflow-hidden bg-navy"
>
  <!-- ── Atmospheric background layers ──────────────────────────── -->
  <!-- Deep glow orbs -->
  <div
    class="pointer-events-none absolute -left-40 top-1/4 h-[600px] w-[600px] rounded-full bg-blue/20 blur-[120px]"
    aria-hidden="true"
  >
  </div>
  <div
    class="pointer-events-none absolute -right-20 top-0 h-[500px] w-[500px] rounded-full bg-cyan/10 blur-[100px]"
    aria-hidden="true"
  >
  </div>
  <div
    class="pointer-events-none absolute bottom-0 right-1/3 h-[400px] w-[400px] rounded-full bg-blue/15 blur-[90px]"
    aria-hidden="true"
  >
  </div>

  <!-- Diagonal grid texture -->
  <div class="hero-grid pointer-events-none absolute inset-0 opacity-[0.04]" aria-hidden="true">
  </div>

  <!-- ── Main content ─────────────────────────────────────────────── -->
  <div
    class="relative mx-auto flex w-full max-w-7xl flex-1 flex-col px-6 pt-32 pb-0 lg:flex-row lg:items-center lg:gap-12 lg:px-8 lg:pt-28"
  >
    <!-- ── Left column: copy & CTAs ────────────────────────────────── -->
    <div class="hero-text flex flex-1 flex-col gap-6 lg:max-w-[54%]">
      <!-- Badge -->
      <div
        class="hero-badge flex w-fit items-center gap-2 rounded-full border border-cyan/25 bg-cyan/8 px-4 py-1.5"
      >
        <span class="inline-block h-2 w-2 animate-pulse rounded-full bg-cyan" aria-hidden="true"
        ></span>
        <span class="font-body text-xs font-semibold uppercase tracking-widest text-cyan">
          Servicio disponible en El Salvador
        </span>
      </div>

      <!-- Headline -->
      <h1
        class="hero-headline font-display text-5xl font-extrabold leading-[1.08] tracking-tight text-white lg:text-6xl xl:text-7xl"
      >
        El confort que<br />
        <span class="relative inline-block">
          <span class="relative z-10 text-cyan">mereces,</span>
          <!-- underline accent -->
          <svg
            class="absolute -bottom-2 left-0 w-full"
            viewBox="0 0 280 12"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
            preserveAspectRatio="none"
          >
            <path
              d="M4 8 Q70 2 140 7 Q210 12 276 5"
              stroke="#50C8FF"
              stroke-width="3"
              stroke-linecap="round"
              fill="none"
              opacity="0.6"></path>
          </svg>
        </span>
        al alcance<br />
        de tu hogar.
      </h1>

      <!-- Sub-headline -->
      <p
        class="hero-sub max-w-xl font-body text-base font-normal leading-relaxed text-white/65 lg:text-lg"
      >
        Instalación, mantenimiento y reparación de aires acondicionados en El&nbsp;Salvador.
        Técnicos certificados, respuesta rápida y garantía en cada trabajo.
      </p>

      <!-- CTAs -->
      <div class="hero-ctas mt-2 flex flex-col gap-3 sm:flex-row sm:items-center">
        <a
          href="#cotizacion"
          class="group inline-flex items-center justify-center gap-2.5 rounded-full bg-cyan px-7 py-3.5 font-display text-sm font-bold text-navy shadow-btn transition-all duration-300 hover:-translate-y-0.5 hover:bg-cyan-light hover:shadow-[0_8px_30px_0_rgb(80_200_255_/0.45)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cyan"
        >
          Solicitar cotización
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            class="transition-transform duration-300 group-hover:translate-x-0.5"
          >
            <path d="M5 12h14M12 5l7 7-7 7"></path>
          </svg>
        </a>

        <a
          href="#servicios"
          class="group inline-flex items-center justify-center gap-2 rounded-full border border-white/20 bg-white/5 px-7 py-3.5 font-display text-sm font-semibold text-white/85 backdrop-blur-sm transition-all duration-300 hover:border-white/40 hover:bg-white/10 hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white/50"
        >
          Ver nuestros servicios
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="15"
            height="15"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            class="transition-transform duration-300 group-hover:translate-y-0.5"
          >
            <path d="M12 5v14M5 12l7 7 7-7"></path>
          </svg>
        </a>
      </div>

      <!-- Trust signals row -->
      <div class="hero-trust mt-2 flex flex-wrap items-center gap-x-5 gap-y-2">
        <div class="flex items-center gap-1.5">
          <!-- Shield icon -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-cyan/70"
            aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg
          >
          <span class="font-body text-xs text-white/50">Trabajo garantizado</span>
        </div>
        <div class="h-3 w-px bg-white/15" aria-hidden="true"></div>
        <div class="flex items-center gap-1.5">
          <!-- Clock icon -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-cyan/70"
            aria-hidden="true"
            ><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"
            ></polyline></svg
          >
          <span class="font-body text-xs text-white/50">Respuesta en &lt;24 horas</span>
        </div>
        <div class="h-3 w-px bg-white/15" aria-hidden="true"></div>
        <div class="flex items-center gap-1.5">
          <!-- Zap icon -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-cyan/70"
            aria-hidden="true"
            ><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg
          >
          <span class="font-body text-xs text-white/50">Cotización personalizada</span>
        </div>
      </div>
    </div>

    <!-- ── Right column: illustration ──────────────────────────────── -->
    <div
      class="hero-illustration relative mt-12 flex flex-1 items-center justify-center lg:mt-0 lg:justify-end"
    >
      <!-- Glow ring behind unit -->
      <div
        class="absolute h-[28rem] w-[28rem] rounded-full bg-cyan/12 blur-2xl lg:h-[32rem] lg:w-[32rem]"
        aria-hidden="true"
      >
      </div>

      <div class="relative">
        <!-- AC Unit SVG Illustration -->
        <svg
          viewBox="0 0 460 340"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          class="ac-unit w-full max-w-lg lg:max-w-xl xl:max-w-2xl"
          role="img"
          aria-label="Ilustración de equipo de aire acondicionado"
        >
          <!-- ── Outer unit body ────────────────────────────────── -->
          <rect x="40" y="100" width="380" height="140" rx="18" fill="#003370"></rect>
          <!-- front panel shine -->
          <rect x="40" y="100" width="380" height="140" rx="18" fill="url(#panelGrad)"></rect>
          <!-- subtle top border shine -->
          <rect x="40" y="100" width="380" height="6" rx="3" fill="url(#shineGrad)" opacity="0.4"
          ></rect>

          <!-- ── Inner recessed panel ───────────────────────────── -->
          <rect x="60" y="118" width="260" height="104" rx="10" fill="#001e45"></rect>
          <!-- front grille bars -->
          <line
            x1="72"
            y1="135"
            x2="308"
            y2="135"
            stroke="#1a8fd1"
            stroke-width="1.5"
            stroke-linecap="round"
            opacity="0.5"></line>
          <line
            x1="72"
            y1="148"
            x2="308"
            y2="148"
            stroke="#1a8fd1"
            stroke-width="1.5"
            stroke-linecap="round"
            opacity="0.5"></line>
          <line
            x1="72"
            y1="161"
            x2="308"
            y2="161"
            stroke="#1a8fd1"
            stroke-width="1.5"
            stroke-linecap="round"
            opacity="0.5"></line>
          <line
            x1="72"
            y1="174"
            x2="308"
            y2="174"
            stroke="#1a8fd1"
            stroke-width="1.5"
            stroke-linecap="round"
            opacity="0.5"></line>
          <line
            x1="72"
            y1="187"
            x2="308"
            y2="187"
            stroke="#1a8fd1"
            stroke-width="1.5"
            stroke-linecap="round"
            opacity="0.5"></line>
          <line
            x1="72"
            y1="200"
            x2="308"
            y2="200"
            stroke="#1a8fd1"
            stroke-width="1.5"
            stroke-linecap="round"
            opacity="0.5"></line>
          <line
            x1="72"
            y1="213"
            x2="308"
            y2="213"
            stroke="#1a8fd1"
            stroke-width="1.5"
            stroke-linecap="round"
            opacity="0.5"></line>

          <!-- ── Control panel (right side) ────────────────────── -->
          <!-- Display screen -->
          <rect x="340" y="122" width="62" height="30" rx="6" fill="#001430"></rect>
          <rect x="344" y="126" width="54" height="22" rx="4" fill="#002850"></rect>
          <!-- Temperature readout -->
          <text
            x="371"
            y="141"
            font-family="monospace"
            font-size="12"
            fill="#50C8FF"
            text-anchor="middle"
            font-weight="700">22°C</text
          >

          <!-- LED indicator row -->
          <circle cx="348" cy="166" r="4" fill="#50C8FF" opacity="0.9"></circle>
          <circle cx="362" cy="166" r="4" fill="#1a8fd1" opacity="0.5"></circle>
          <circle cx="376" cy="166" r="4" fill="#1a8fd1" opacity="0.5"></circle>

          <!-- Power button -->
          <circle
            cx="371"
            cy="192"
            r="10"
            fill="#002147"
            stroke="#50C8FF"
            stroke-width="1.5"
            opacity="0.8"></circle>
          <path d="M371 184 L371 189" stroke="#50C8FF" stroke-width="2" stroke-linecap="round"
          ></path>
          <path
            d="M365 187 Q361 192 365 197 Q368 200 371 200 Q374 200 377 197 Q381 192 377 187"
            stroke="#50C8FF"
            stroke-width="1.5"
            stroke-linecap="round"
            fill="none"></path>

          <!-- ── Airflow vane at bottom ──────────────────────────── -->
          <rect x="60" y="226" width="260" height="8" rx="4" fill="#1a8fd1" opacity="0.4"></rect>
          <rect x="72" y="229" width="236" height="2" rx="1" fill="#50C8FF" opacity="0.3"></rect>

          <!-- Bottom lip -->
          <rect x="40" y="228" width="380" height="12" rx="6" fill="#002147"></rect>

          <!-- Mounting tabs -->
          <rect x="70" y="236" width="30" height="8" rx="4" fill="#001e45"></rect>
          <rect x="360" y="236" width="30" height="8" rx="4" fill="#001e45"></rect>

          <!-- ── Cool air flow waves ─────────────────────────────── -->
          <!-- Wave 1 — leftmost, tallest -->
          <path
            class="wave wave-1"
            d="M 90 264 Q 110 248 130 258 Q 150 268 170 255 Q 190 242 210 252"
            stroke="#50C8FF"
            stroke-width="2.5"
            stroke-linecap="round"
            fill="none"
            opacity="0.7"></path>
          <!-- Wave 2 — mid -->
          <path
            class="wave wave-2"
            d="M 110 276 Q 133 260 156 270 Q 179 280 202 267 Q 225 254 248 264"
            stroke="#50C8FF"
            stroke-width="2"
            stroke-linecap="round"
            fill="none"
            opacity="0.5"></path>
          <!-- Wave 3 — widest -->
          <path
            class="wave wave-3"
            d="M 78 290 Q 106 272 134 284 Q 162 296 190 280 Q 218 264 246 276 Q 268 285 290 272"
            stroke="#3aaee0"
            stroke-width="1.5"
            stroke-linecap="round"
            fill="none"
            opacity="0.35"></path>
          <!-- Wave 4 — faintest, lowest -->
          <path
            class="wave wave-4"
            d="M 68 308 Q 100 288 132 301 Q 164 314 196 297 Q 228 280 260 293 Q 280 302 300 290"
            stroke="#50C8FF"
            stroke-width="1"
            stroke-linecap="round"
            fill="none"
            opacity="0.2"></path>

          <!-- ── Floating particles ─────────────────────────────── -->
          <circle class="particle p1" cx="100" cy="78" r="3" fill="#50C8FF" opacity="0.6"></circle>
          <circle class="particle p2" cx="200" cy="62" r="2" fill="#3aaee0" opacity="0.5"></circle>
          <circle class="particle p3" cx="310" cy="72" r="2.5" fill="#50C8FF" opacity="0.4"
          ></circle>
          <circle class="particle p4" cx="150" cy="88" r="1.5" fill="#50C8FF" opacity="0.7"
          ></circle>
          <circle class="particle p5" cx="260" cy="82" r="2" fill="#3aaee0" opacity="0.5"></circle>

          <!-- ── Gradient defs ──────────────────────────────────── -->
          <defs>
            <linearGradient
              id="panelGrad"
              x1="40"
              y1="100"
              x2="40"
              y2="240"
              gradientUnits="userSpaceOnUse"
            >
              <stop offset="0%" stop-color="#1a8fd1" stop-opacity="0.15"></stop>
              <stop offset="100%" stop-color="#002147" stop-opacity="0"></stop>
            </linearGradient>
            <linearGradient
              id="shineGrad"
              x1="40"
              y1="0"
              x2="420"
              y2="0"
              gradientUnits="userSpaceOnUse"
            >
              <stop offset="0%" stop-color="#ffffff" stop-opacity="0"></stop>
              <stop offset="40%" stop-color="#50C8FF" stop-opacity="1"></stop>
              <stop offset="100%" stop-color="#ffffff" stop-opacity="0"></stop>
            </linearGradient>
          </defs>
        </svg>

        <!-- Floating badge: "Técnicos Certificados" -->
        <div
          class="float-badge absolute -right-4 top-8 flex items-center gap-2 rounded-2xl border border-cyan/20 bg-navy/90 px-4 py-2.5 shadow-card backdrop-blur-md lg:-right-6"
        >
          <div class="flex h-8 w-8 items-center justify-center rounded-full bg-cyan/15">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-cyan"
              aria-hidden="true"
              ><path
                d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 21 12 17.77 5.82 21 7 14.14 2 9.27l6.91-1.01L12 2z"
              ></path></svg
            >
          </div>
          <div>
            <p class="font-display text-xs font-bold text-white">Técnicos Certificados</p>
            <p class="font-body text-xs text-white/50">Multimarca · Garantía incluida</p>
          </div>
        </div>

        <!-- Floating badge: "Emergencia" -->
        <div
          class="float-badge-2 absolute -left-4 bottom-16 flex items-center gap-2 rounded-2xl border border-blue/20 bg-navy/90 px-4 py-2.5 shadow-card backdrop-blur-md lg:-left-6"
        >
          <div class="flex h-8 w-8 items-center justify-center rounded-full bg-blue/20">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-blue-light"
              aria-hidden="true"
              ><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg
            >
          </div>
          <div>
            <p class="font-display text-xs font-bold text-white">Emergencia 24/7</p>
            <p class="font-body text-xs text-white/50">Los 7 días · Sin recargo</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Stats strip ──────────────────────────────────────────────── -->
  <div class="hero-stats relative mt-12 border-t border-white/8 lg:mt-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="grid grid-cols-2 divide-x divide-white/8 lg:grid-cols-4">
        {
          stats.map((stat) => (
            <div class="flex flex-col items-center gap-1 px-6 py-7 text-center">
              <span class="font-display text-3xl font-extrabold tracking-tight text-cyan lg:text-4xl">
                {stat.value}
              </span>
              <span class="font-body text-xs font-medium uppercase tracking-wider text-white/45">
                {stat.label}
              </span>
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <!-- ── Scroll indicator ─────────────────────────────────────────── -->
  <div
    class="pointer-events-none absolute bottom-32 left-1/2 hidden -translate-x-1/2 flex-col items-center gap-2 lg:flex"
    aria-hidden="true"
  >
    <div class="scroll-mouse h-9 w-5 rounded-full border border-white/20 p-1">
      <div class="scroll-dot mx-auto h-1.5 w-1.5 animate-bounce rounded-full bg-cyan/60"></div>
    </div>
  </div>
</section>

<style>
  /* ── Diagonal grid texture ─────────────────────────────────── */
  .hero-grid {
    background-image:
      linear-gradient(45deg, #50c8ff 1px, transparent 1px),
      linear-gradient(-45deg, #50c8ff 1px, transparent 1px);
    background-size: 60px 60px;
  }

  /* ── AC wave animations ──────────────────────────────────── */
  .wave {
    stroke-dasharray: 300;
    stroke-dashoffset: 300;
    animation: drawWave 2s ease-out forwards;
  }
  .wave-1 {
    animation-delay: 0.8s;
  }
  .wave-2 {
    animation-delay: 1.1s;
  }
  .wave-3 {
    animation-delay: 1.4s;
  }
  .wave-4 {
    animation-delay: 1.7s;
  }

  @keyframes drawWave {
    to {
      stroke-dashoffset: 0;
    }
  }

  /* ── Particles float ─────────────────────────────────────── */
  .particle {
    animation: floatUp 3s ease-in-out infinite;
  }
  .p1 {
    animation-delay: 0s;
    animation-duration: 3.2s;
  }
  .p2 {
    animation-delay: 0.5s;
    animation-duration: 2.8s;
  }
  .p3 {
    animation-delay: 1s;
    animation-duration: 3.5s;
  }
  .p4 {
    animation-delay: 1.5s;
    animation-duration: 2.6s;
  }
  .p5 {
    animation-delay: 0.8s;
    animation-duration: 3.1s;
  }

  @keyframes floatUp {
    0%,
    100% {
      transform: translateY(0);
      opacity: 0.6;
    }
    50% {
      transform: translateY(-12px);
      opacity: 0.2;
    }
  }

  /* ── AC unit entrance ────────────────────────────────────── */
  .ac-unit {
    animation: unitReveal 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both;
  }
  @keyframes unitReveal {
    from {
      opacity: 0;
      transform: translateY(24px) scale(0.97);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  /* ── Floating badges ─────────────────────────────────────── */
  .float-badge {
    animation: floatBadge 4s ease-in-out infinite;
  }
  .float-badge-2 {
    animation: floatBadge 4s ease-in-out 1.5s infinite;
  }

  @keyframes floatBadge {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-6px);
    }
  }

  /* ── Text reveal animations ─────────────────────────────── */
  .hero-badge,
  .hero-headline,
  .hero-sub,
  .hero-ctas,
  .hero-trust {
    animation: fadeSlideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .hero-badge {
    animation-delay: 0.1s;
  }
  .hero-headline {
    animation-delay: 0.2s;
  }
  .hero-sub {
    animation-delay: 0.35s;
  }
  .hero-ctas {
    animation-delay: 0.5s;
  }
  .hero-trust {
    animation-delay: 0.65s;
  }

  .hero-illustration {
    animation: fadeSlideUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.25s both;
  }
  .hero-stats {
    animation: fadeSlideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.6s both;
  }

  @keyframes fadeSlideUp {
    from {
      opacity: 0;
      transform: translateY(28px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ── Respeta preferencias de movimiento reducido (WCAG 2.3.3) ── */
  @media (prefers-reduced-motion: reduce) {
    .wave,
    .particle,
    .ac-unit,
    .float-badge,
    .float-badge-2,
    .hero-badge,
    .hero-headline,
    .hero-sub,
    .hero-ctas,
    .hero-trust,
    .hero-illustration,
    .hero-stats {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
      stroke-dashoffset: 0 !important;
    }
  }
</style>

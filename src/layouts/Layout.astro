---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalUrl?: string;
  robots?: string;
}

const {
  title = 'Clima Hogar SV — Instalación y Mantenimiento de Aire Acondicionado en El Salvador',
  description = 'Empresa especializada en instalación, mantenimiento y reparación de aires acondicionados en El Salvador. Técnicos certificados y presupuesto sin costo.',
  image = '/og-image.jpg',
  canonicalUrl = Astro.url.href,
  robots = 'index, follow',
} = Astro.props;

const siteName = 'Clima Hogar SV';
const twitterHandle = '@climahogarsv';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- ── Favicon ──────────────────────────────────────────────── -->
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="apple-touch-icon" href="/logo.png" />

    <!-- ── SEO primario ─────────────────────────────────────────── -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="aire acondicionado El Salvador, instalación aire acondicionado, mantenimiento aire acondicionado, reparación aire acondicionado, técnicos certificados, San Salvador"
    />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- ── Open Graph (Facebook, WhatsApp, LinkedIn) ────────────── -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url).href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="es_SV" />

    <!-- ── Twitter Card ─────────────────────────────────────────── -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={twitterHandle} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.url).href} />

    <!-- ── Fuentes (preconnect antes que el import en global.css) ── -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body class="bg-white font-body text-gray-900 antialiased">
    <slot />

    <!-- ── Back to top ───────────────────────────────────────────── -->
    <button
      id="back-to-top"
      type="button"
      aria-label="Volver al inicio de la página"
      class="fixed bottom-6 right-6 z-50 flex h-11 w-11 items-center justify-center rounded-full bg-navy shadow-card-hover ring-1 ring-cyan/30 transition-all duration-300 hover:-translate-y-1 hover:bg-navy-light hover:ring-cyan/60 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cyan"
      style="pointer-events: none;"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="#50C8FF"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M12 19V5M5 12l7-7 7 7"></path>
      </svg>
    </button>

    <script>
      const btn = document.getElementById('back-to-top') as HTMLButtonElement;
      const THRESHOLD = 400;

      // Set initial hidden state
      btn.style.opacity = '0';
      btn.style.transform = 'translateY(1rem)';
      btn.style.pointerEvents = 'none';

      function syncVisibility() {
        const visible = window.scrollY > THRESHOLD;
        btn.style.opacity = visible ? '1' : '0';
        btn.style.transform = visible ? '' : 'translateY(1rem)';
        btn.style.pointerEvents = visible ? 'auto' : 'none';
      }

      window.addEventListener('scroll', syncVisibility, { passive: true });

      btn.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    </script>
  </body>
</html>
